      Area == "Friuli_Venezia_Giulia" ~ "Friuli-Venezia Giulia",
      Area == "Emilia_Romagna" ~ "Emilia-Romagna",
      Area == "Trentino_Alto_Adige" ~ "Trentino-Alto Adige",
      TRUE ~ Area
    ),
    # Correzione Valle d'Aosta
    Reddito = case_when(
      Area == "Valle_D_Aosta" & Anno == 2016 ~ 20.996,
      Area == "Valle_D_Aosta" & Anno == 2024 ~ 24.980,
      TRUE ~ Reddito
    )
  )

nic_regioni <- nic_regioni %>%
  mutate(
    regione_nostra = case_when(
      Area == "Valle_d_Aosta" ~ "Valle d'Aosta",
      Area == "Friuli_Venezia_Giulia" ~ "Friuli-Venezia Giulia",
      Area == "Emilia_Romagna" ~ "Emilia-Romagna",
      Area == "Trentino_Alto_Adige" ~ "Trentino-Alto Adige",
      TRUE ~ Area
    )
  )

