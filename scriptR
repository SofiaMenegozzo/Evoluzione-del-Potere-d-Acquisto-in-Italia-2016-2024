# Funzione di normalizzazione
normalizza <- function(x) {
  (x - min(x, na.rm = TRUE)) / (max(x, na.rm = TRUE) - min(x, na.rm = TRUE)) * 100
}

# Calcolo indicatori normalizzati
dati_benessere_norm <- dati_benessere %>%
  group_by(Area) %>%
  mutate(
    Reddito_norm = normalizza(Reddito),
    Disoccupazione_inv = max(Disoccupazione, na.rm = TRUE) - Disoccupazione,
    Disoccupazione_norm = normalizza(Disoccupazione_inv),
    Poverta_inv = max(Poverta, na.rm = TRUE) - Poverta,
    Poverta_norm = normalizza(Poverta_inv),
    Benessere = (Reddito_norm + Disoccupazione_norm + Poverta_norm) / 3
  ) %>%
  ungroup() %>%
  mutate(across(where(is.numeric), ~ round(.x, 1)))

write.csv2(dati_benessere_norm, "~/Desktop/progetto/indicatori_benessere.csv", row.names = FALSE)

