potere_regionale <- regioni_reddito %>%
  filter(Anno %in% c(2016, 2024)) %>%
  left_join(nic_regioni %>% filter(Anno %in% c(2016, 2024)),
            by = c("Anno", "regione_nostra")) %>%
  mutate(Potere_Acquisto = Reddito / Indice_generale * 100) %>%
  select(Anno, regione_nostra, Potere_Acquisto)

# Creazione tabella confronto
dati_2016 <- potere_regionale %>% filter(Anno == 2016) %>%
  select(regione_nostra, Potere_2016 = Potere_Acquisto)

dati_2024 <- potere_regionale %>% filter(Anno == 2024) %>%
  select(regione_nostra, Potere_2024 = Potere_Acquisto)

tabella_regionale <- full_join(dati_2016, dati_2024, by = "regione_nostra") %>%
  mutate(
    Variazione = Potere_2024 - Potere_2016,
    Variazione_perc = (Potere_2024 / Potere_2016 - 1) * 100
  ) %>%
  mutate(across(where(is.numeric), ~ round(.x, 2)))

print("Tabella potere d'acquisto regionale:")
